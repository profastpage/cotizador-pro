/*.html
  # HTML files - always serve fresh
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/assets/*.js
  # JS files have content hashes - safe to cache
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  # CSS files have content hashes - safe to cache
  Cache-Control: public, max-age=31536000, immutable

/og-image.png
  # Open Graph image - allow caching
  Cache-Control: public, max-age=86400
  Content-Type: image/png

/icon-192.png
  # PWA icon - allow caching
  Cache-Control: public, max-age=86400
  Content-Type: image/png

/icon-512.png
  # PWA icon - allow caching
  Cache-Control: public, max-age=86400
  Content-Type: image/png

/icon.svg
  # Favicon SVG - allow caching
  Cache-Control: public, max-age=86400
  Content-Type: image/svg+xml

/sw.js
  # Service Worker - must not cache
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.json
  # PWA manifest - allow caching
  Cache-Control: public, max-age=3600
