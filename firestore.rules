rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================================
    // FUNCIONES AUXILIARES
    // ==========================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }
    
    function isActiveUser() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true;
    }
    
    function hasValidPlan() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.plan != null;
    }
    
    // ==========================================================
    // USERS - Permite crear, leer y buscar por email
    // ==========================================================
    match /users/{userId} {
      // Lectura: propio usuario o admin
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Creación: cualquier usuario autenticado puede crear su propio doc
      // (necesario para migración y registro)
      allow create: if isAuthenticated();
      
      // Actualización: propio usuario o admin
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Eliminación: solo admin
      allow delete: if isAdmin();
    }
    
    // ==========================================================
    // QUOTES - Solo el propietario puede acceder a sus cotizaciones
    // ==========================================================
    match /quotes/{quoteId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       isActiveUser() &&
                       hasValidPlan() &&
                       request.resource.data.keys().hasAll(['userId', 'client', 'items', 'total']);
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
    }
    
    // ==========================================================
    // CLIENTS - Solo el propietario puede acceder a sus clientes
    // ==========================================================
    match /clients/{clientId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       isActiveUser();
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
    }
    
    // ==========================================================
    // COMPANIES - Solo el propietario puede acceder a su empresa
    // ==========================================================
    match /companies/{companyId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       isActiveUser();
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAdmin();
    }
    
    // ==========================================================
    // SHARED_QUOTES - Lectura pública, escritura solo autenticados
    // ==========================================================
    match /shared_quotes/{shareId} {
      allow read: if true;
      
      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAdmin();
    }
    
    // ==========================================================
    // ITEM_CATALOG - Solo el propietario puede acceder a sus items
    // ==========================================================
    match /itemCatalog/{itemId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       isActiveUser();
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
    }
    
    // ==========================================================
    // EXPENSES - Solo el propietario puede acceder a sus gastos
    // ==========================================================
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && 
                     (isOwner(resource.data.userId) || isAdmin());
      
      allow create: if isAuthenticated() && 
                       isOwner(request.resource.data.userId) &&
                       isActiveUser();
      
      allow update: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
      
      allow delete: if isAuthenticated() && 
                       (isOwner(resource.data.userId) || isAdmin());
    }
    
    // ==========================================================
    // DENY ALL por defecto
    // ==========================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
